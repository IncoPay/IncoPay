{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "facilitator": "tsx app/facilator/server.ts",
    "deploy-token": "tsx app/facilator/deploy-token.ts",
    "kora:install": "cd ../kora && make install && cd ../my-app",
    "kora:build-sdk": "cd ../kora/sdks/ts && npm install --ignore-scripts && npx tsc && cd ../../../my-app",
    "deploy-inco-token": "cd lightning-rod-solana && solana program deploy --program-id target/deploy/inco_token-keypair.json target/deploy/inco_token.so --url devnet --max-sign-attempts 1000 && cp target/idl/inco_token.json ../public/idl/inco_token.json && cd ..",
    "copy-idl": "cd lightning-rod-solana && cp target/idl/inco_token.json ../public/idl/inco_token.json && cd ..",
    "setup-inco-token": "tsx scripts/setup-inco-token.ts",
    "kora:start": "./start-kora.sh"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.0",
    "@inco/solana-sdk": "^0.0.2",
    "@solana/kora": "file:../kora/sdks/ts",
    "@solana/spl-token": "^0.4.8",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@solana/web3.js": "^1.98.4",
    "@x402/core": "^2.0.0",
    "@x402/svm": "^2.0.0",
    "axios": "^1.8.4",
    "bs58": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "define-data-property": "^1.1.4",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.563.0",
    "motion": "^12.25.0",
    "next": "16.1.1",
    "ogl": "^1.0.11",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0",
    "three": "^0.167.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  },
  "packageManager": "yarn@3.2.3+sha512.f26f951f67de0c6a33ee381e5ff364709c87e70eb5e65c694e4facde3512f1fa80b8679e6ba31ce7d340fbb46f08dd683af9457e240f25a204be7427940d767e",
  "resolutions": {
    "@solana/errors": "^2.0.0",
    "@solana/codecs-core": "^2.0.0"
  }
}
